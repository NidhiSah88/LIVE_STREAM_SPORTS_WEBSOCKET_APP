


```gitignore
# dependencies
node_modules/

# environment variables
.env
.env.*
!.env.example

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# build output
dist/
build/

# cache
.cache/
.tmp/
temp/

# macOS
.DS_Store

# VS Code
.vscode/

# JetBrains
.idea/

# TypeScript
*.tsbuildinfo

# coverage
coverage/

# Drizzle generated files (optional)
drizzle/meta/

# runtime files
*.pid

# thunder client local files (optional)
.thunder-client/

# package manager
.pnpm-store/
```





