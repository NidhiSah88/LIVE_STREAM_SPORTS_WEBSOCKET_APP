const ws = new WebSocket("ws://localhost:8080/ws");

ws.onopen = () => {
  console.log("CONNECTED");
};

ws.onmessage = (event) => {
  console.log("MESSAGE:", event.data);
};

ws.onclose = (event) => {
  console.log(
    "CLOSED",
    event.code,
    event.reason
  );
};

ws.onerror = (err) => {
  console.log("ERROR", err);
};

