Now your WebSocket subscription flow is working correctly 🎉

Open 3 separate browser windows/tabs → open DevTools → Console.

Browser Console 1 → Subscribe to Match 1 (should receive commentary)
window.fan1 =
new WebSocket(
"ws://localhost:8080/ws"
);

fan1.onopen = () =>
console.log("Fan1 OPEN");

fan1.onmessage = (e) => {
  const msg =
    JSON.parse(e.data);

  console.log(
    "[FAN1]",
    msg
  );

  if (
    msg.type ===
    "welcome"
  ) {
    fan1.send(
      JSON.stringify({
        type:
          "subscribe",
        matchId: 1
      })
    );

    console.log(
      "Fan1 subscribed → Match 1"
    );
  }
};

fan1.onclose =
console.log;

fan1.onerror =
console.log;

Expected:

Fan1 OPEN
[FAN1] {type:"welcome"}
Fan1 subscribed → Match 1
[FAN1] {type:"subscribed", matchId:1}
